# MongoDB
MONGODB_URI=mongodb://openplannerRoot:change-me-root-password@mongodb:27017/openplanner?authSource=admin&directConnection=true
OPENPLANNER_STORAGE_BACKEND=mongodb

# Ollama / Proxx — used for LLM calls and embeddings
OPENPLANNER_OLLAMA_BASE_URL=http://openplanner-openplanner-proxx-1:8789
OPEN_HAX_OPENAI_PROXY_AUTH_TOKEN=change-me-openplanner-proxx-token

# Embedding provider (reads from compose: EMBED_PROVIDER_BASE_URL defaults to OPENPLANNER_OLLAMA_BASE_URL)
# These are picked up by docker compose automatically
