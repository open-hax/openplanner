# OpenPlanner
OPENPLANNER_DATA_DIR=./openplanner-lake
OPENPLANNER_HOST=127.0.0.1
OPENPLANNER_PORT=7777

# Simple auth (single-user local-first)
# Use: Authorization: Bearer <OPENPLANNER_API_KEY>
OPENPLANNER_API_KEY=change-me

# Storage backend: duckdb (default) or mongodb
OPENPLANNER_STORAGE_BACKEND=duckdb

# MongoDB configuration (when STORAGE_BACKEND=mongodb)
MONGODB_URI=mongodb://localhost:27017/openplanner?replicaSet=rs0
MONGODB_DB=openplanner
MONGODB_EVENTS_COLLECTION=events
MONGODB_COMPACTED_COLLECTION=compacted_memories
MONGODB_VECTOR_HOT_COLLECTION=event_chunks
MONGODB_VECTOR_COMPACT_COLLECTION=compacted_vectors
OPENPLANNER_MONGOT_PORT=27028

# In MongoDB mode, vector search persistence lives in the two collections above.
# MongoDB native vector search requires MongoDB 8.2 + mongot + replica set mode.
# Chroma remains available as the legacy source/rollback target for reversible migration.

# MongoDB TTL settings (seconds, 0 = disabled)
# Recommended values:
#   - 30 days: 2592000
#   - 90 days: 7776000
# Events: auto-expire perception signals, chat logs, etc.
MONGODB_EVENTS_TTL_SECONDS=2592000
# Compacted memories: longer retention for summarized data
MONGODB_COMPACTED_TTL_SECONDS=7776000

# ChromaDB (vector search)
CHROMA_URL=http://127.0.0.1:8000
CHROMA_COLLECTION=openplanner_events_v1
CHROMA_COMPACT_COLLECTION=openplanner_events_v1_compact

# Ollama embeddings
OLLAMA_BASE_URL=http://127.0.0.1:8789
OLLAMA_EMBED_MODEL=qwen3-embedding:0.6b
# Scope overrides (supports either JSON or key=value pairs separated by ';' or ',')
# OLLAMA_EMBED_MODEL_BY_SOURCE={"chatgpt-export":"qwen3-embedding:4b"}
# OLLAMA_EMBED_MODEL_BY_KIND=message=qwen3-embedding:0.6b
# OLLAMA_EMBED_MODEL_BY_PROJECT=chatgpt=qwen3-embedding:4b